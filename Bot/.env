# ─── v6.1: Gölge Modu (Shadow Mode / Kuru Sıkı) ───
EXECUTION_ENABLED=false

# ─── v15.0: RPC Failover & Gecikme Ayarları ───
# Yedek RPC URL (opsiyonel — primary başarısız olursa kullanılır)
# Örnek: RPC_WSS_URL_BACKUP=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_WSS_URL_BACKUP=
# Gecikme spike uyarı eşiği (ms) — bu değerin üzerinde log uyarısı
LATENCY_SPIKE_THRESHOLD_MS=200

# ─── v15.0: MEV Koruması (Canlı Mod İçin) ───
# Flashbots Protect kullanmak için primary RPC'yi değiştirin:
# RPC_WSS_URL=wss://rpc.flashbots.net  (veya Base ağı private RPC)
# Deadline: TX kaç blok içinde mine edilmezse geçersiz sayılır
DEADLINE_BLOCKS=2