POOL_A_NAME=PancakeSwapV3
POOL_A_FEE_BPS=1
POOL_A_DEX=pancakeswap
POOL_A_TICK_SPACING=1

# ─── Havuz B (Uniswap V3 WETH/USDC %0.01 — 1 bps, tick spacing=1) ───
# Yüksek volatilite çifti — HFT arbitraj için daha uygun spread fırsatları
POOL_B_ADDRESS=0xd0b53D9277642d899DF5C87A3966A349A798F224
POOL_B_NAME=UniswapV3
POOL_B_FEE_BPS=1
POOL_B_DEX=uniswap
POOL_B_TICK_SPACING=1

# ─── Token Ayarları (WETH/USDC Paritesi) ───
WETH_ADDRESS=0x4200000000000000000000000000000000000006
QUOTE_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
QUOTE_TOKEN_DECIMALS=6
WETH_IS_TOKEN0=true
TOKEN0_DECIMALS=18
TOKEN1_DECIMALS=6

# ─── Maliyet ve Strateji (WETH cinsinden) ───
GAS_COST_FALLBACK_WETH=0.00005
FLASH_LOAN_FEE_BPS=0.0
MIN_NET_PROFIT_WETH=0.0001
MAX_TRADE_SIZE_WETH=50.0
