# ═══════════════════════════════════════════════════════════════════════════════
#  Kuantum Beyin IV v25.0 — Base Mainnet Production .env
#  Son güncelleme: 2025-07-12
#
#  ⚠ Bu dosya SADECE altyapı değişkenlerini içerir.
#  Havuz ve token bilgileri matched_pools.json'dan otomatik yüklenir.
#  POOL_A_*, POOL_B_*, WETH_ADDRESS, QUOTE_TOKEN_* gibi legacy
#  değişkenler artık bot tarafından okunMAZ.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── RPC Bağlantıları (dRPC Primary + Alchemy Backup — Base Mainnet) ───
RPC_WSS_URL=wss://lb.drpc.live/base/AvcMunYzE0LBv6TfiFlOGUGaAUf8HlMR8aL5dg7bSgwO
RPC_HTTP_URL=https://lb.drpc.live/base/AvcMunYzE0LBv6TfiFlOGUGaAUf8HlMR8aL5dg7bSgwO
RPC_WSS_URL_BACKUP=wss://base-mainnet.g.alchemy.com/v2/GtUd8rIs9qQ7MvXoBxOEF
RPC_WSS_URL_2=
RPC_WSS_URL_3=
RPC_IPC_PATH=
TRANSPORT_MODE=auto

# ─── Zincir Ayarı (Base) ───
CHAIN_ID=8453

# ─── Cüzdan ve Kontrat ───
# ⚠ ÖNEMLİ: Aşağıdaki key Anvil test key'idir — GERÇEK FONLARLA KULLANMAYIN!
# Üretime geçmeden önce: cargo run -- --encrypt-key ile keystore oluşturun.
# ⚠ ASLA gerçek private key'i bu dosyaya yazmayın — keystore kullanın!
PRIVATE_KEY=
KEYSTORE_PATH=
ARBITRAGE_CONTRACT_ADDRESS=0x86D0fA6B6Feab2dEC370132e19c6a8154Fe0f5C4

# ─── MEV Koruması ───
# v25.0: Base L2 MEV koruması — Flashbots Protect (Base ağı desteği).
# Base sequencer FIFO sıralama kullanır; Flashbots Protect Base üzerinden
# TX'ler doğrudan builder'lara iletilir, public mempool'a düşmez.
# Alternatifler: https://rpc.titanbuilder.xyz, https://rpc.beaverbuild.org
PRIVATE_RPC_URL=https://rpc.flashbots.net?chainId=8453

# ─── Maliyet ve Strateji (WETH cinsinden) ───
GAS_COST_FALLBACK_WETH=0.00005
FLASH_LOAN_FEE_BPS=0.0
# v28.0: Minimum net kâr eşiği — gas maliyetini karşılayacak seviye
MIN_NET_PROFIT_WETH=0.0001
# v28.0: MAX_TRADE_SIZE_WETH 50 → 5 WETH. Base L2 havuzlarının gerçek
# kullanılabilir likiditesi genelde 0.05-2 WETH aralığındadır.
# Bot zaten effective_cap ile havuz derinliğine göre kırpar; bu değer üst sınırdır.
# 50 WETH default'u NR tarama aralığını gereksiz genişletir ve hesaplama süresi harcar.
MAX_TRADE_SIZE_WETH=5.0
# v10.0: Hard-Abort eşiği — 1000ms üstü veri ile arbitraj İPTAL EDİLİR.
# is_fresh() = is_active() + staleness_ms() <= MAX_STALENESS_MS
# Base L2 blok süresi ~2s; 1000ms eşiği mevcut bloğun verisi ile işlem yapmayı garanti eder.
MAX_STALENESS_MS=1000
STATS_INTERVAL=10
MAX_RETRIES=0
MAX_POOL_FEE_BPS=100

# ─── TickBitmap Derinlik Ayarları ───
TICK_BITMAP_RANGE=100
# v28.0: TickBitmap'in kaç blok eskiyene kadar geçerli sayılacağı.
# Eski bitmap ile hesaplama hatalı likidite tahmini ve MEV açığı yaratır.
# Bitmap yaşı bu eşiği aştığında tek-tick fallback kullanılır.
TICK_BITMAP_MAX_AGE_BLOCKS=5

# ─── Gölge Modu (Shadow Mode) ───
# false = TX göndermez, sadece loglar. Canlıya geçmeden önce test edin.
EXECUTION_ENABLED=false

# ─── RPC Failover & Gecikme Ayarları ───
# v24.0: Latency spike eşiği düşürüldü — 200ms üzeri fırsatın kaçma riski yüksek.
# Yerel node (IPC) veya coğrafi olarak yakın sunucu kullanarak <50ms hedeflenmelidir.
# Base sequencer'a en yakın bölge: AWS us-east-1 (Virginia)
LATENCY_SPIKE_THRESHOLD_MS=100

# ─── MEV & TX Ayarları ───
# v22.0: Deadline artırıldı 2 → 3 blok (Base ~2s blok süresi = ~6s pencere)
# 2 blok çok dar → RPC gecikmesi veya network yoğunluğunda timeout riski yüksek
DEADLINE_BLOCKS=3
BRIBE_PCT=0.25
CIRCUIT_BREAKER_THRESHOLD=3

# ─── Admin (Fon çekme adresi — opsiyonel) ───
ADMIN_ADDRESS=