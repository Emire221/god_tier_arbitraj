# ─── MEV Koruması ───
# Base ağı Private RPC (Flashbots Protect / bloXroute vb.)
PRIVATE_RPC_URL=

# ─── Havuz A (PancakeSwap V3 WETH/cbBTC %0.01 — 1 bps, tick spacing=1) ───
