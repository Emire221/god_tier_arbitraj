# Example .env (do NOT store real private keys here)

# RPC connections (replace with your endpoints)
RPC_WSS_URL=ws://YOUR_RPC_WSS_URL
RPC_HTTP_URL=http://YOUR_RPC_HTTP_URL
RPC_IPC_PATH=
TRANSPORT_MODE=auto

# Chain (Base)
CHAIN_ID=8453

# Wallet and contract (use placeholders)
PRIVATE_KEY=0xREDACTED_PRIVATE_KEY
ARBITRAGE_CONTRACT_ADDRESS=0x86D0fA6B6Feab2dEC370132e19c6a8154Fe0f5C4

# Pool A (PancakeSwap V3 WETH/cbBTC 0.01%)
POOL_A_ADDRESS=0xc211e1f853A898BD1302385ccdE55F33A8C4b3f3
POOL_A_NAME=PancakeSwapV3
POOL_A_FEE_BPS=1
POOL_A_DEX=uniswap
POOL_A_TICK_SPACING=1

# Pool B (Aerodrome SlipStream WETH/cbBTC 0.05%)
POOL_B_ADDRESS=0x70aCDF2Ad0Bf2402c957154f944c19Ef4e1cbAE1
POOL_B_NAME=Aerodrome
POOL_B_FEE_BPS=5
POOL_B_DEX=aerodrome
POOL_B_TICK_SPACING=100

# Token settings
WETH_ADDRESS=0x4200000000000000000000000000000000000006
QUOTE_TOKEN_ADDRESS=0xcbB7C0000aB88B473b1f5aFd9ef808440eed33Bf
QUOTE_TOKEN_DECIMALS=8
WETH_IS_TOKEN0=true
TOKEN0_DECIMALS=18
TOKEN1_DECIMALS=8

# Costs & strategy (all in WETH)
GAS_COST_FALLBACK_WETH=0.00005
FLASH_LOAN_FEE_BPS=0.0
MIN_NET_PROFIT_WETH=0.0001
MAX_TRADE_SIZE_WETH=50.0
MAX_STALENESS_MS=2000
STATS_INTERVAL=10
MAX_RETRIES=0

# TickBitmap
TICK_BITMAP_RANGE=10
TICK_BITMAP_MAX_AGE_BLOCKS=5

# Shadow Mode
EXECUTION_ENABLED=false
